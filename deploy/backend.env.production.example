# ============================================================
#  La Campeona 880 AM — Production .env
#  Location: /opt/lacampeona/backend/.env
#  Domain  : lacampeona880am.com
#  Port    : 8006
#  >>> COPY THIS FILE to /opt/lacampeona/backend/.env AND EDIT
# ============================================================

# --- MongoDB (local on the same cPanel box) ---
MONGO_URL=mongodb://localhost:27017
DB_NAME=radio_latina_prod

# --- CORS — exact production domain (DO NOT use *) ---
CORS_ORIGINS=https://lacampeona880am.com,https://www.lacampeona880am.com

# --- JWT — generate a NEW long random secret for prod ---
# Run: openssl rand -hex 64
JWT_SECRET=REPLACE_WITH_64_CHAR_HEX_FROM_openssl_rand_hex_64
JWT_EXPIRY_HOURS=12

# --- Admin (technical / fallback) ---
ADMIN_EMAIL=admin@lacampeona880am.com
ADMIN_PASSWORD=REPLACE_WITH_STRONG_PASSWORD

# --- Super Admin (the station owner) ---
SUPER_ADMIN_EMAIL=pzsuave007@gmail.com
SUPER_ADMIN_PASSWORD=MXmedia007

# --- Demo DJ (optional — remove after creating real DJs in /super) ---
DJ_EMAIL=dj@lacampeona880am.com
DJ_PASSWORD=REPLACE_WITH_STRONG_PASSWORD

# --- Emergent LLM key (object storage for AI-generated images) ---
EMERGENT_LLM_KEY=sk-emergent-eEbDa9fBf2b61E3F28

# --- OpenAI (Content Studio / DJ Studio AI — station's OWN key) ---
# Texto: /dj/suggest, /dj/generate, expandir noticias.  Imágenes: /dj/generate-image (gpt-image-1).
OPENAI_API_KEY=REPLACE_WITH_YOUR_OPENAI_KEY
OPENAI_TEXT_MODEL=gpt-4o
OPENAI_IMAGE_MODEL=gpt-image-1

# --- App identity ---
APP_NAME=la-campeona-880am

# --- Public base URL for social-share preview links (Open Graph) ---
PUBLIC_BASE_URL=https://lacampeona880am.com
